# Add these in Cloudflare Dashboard → Pages → Settings → Environment Variables
# Never put your real keys here or commit this file with real values

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
QWEN_API_KEY=sk-your-qwen-key-here

# Optional: protects app with a password
# Leave empty to disable password protection
APP_PASSWORD=choose-a-password-here
